frontend/out/
frontend/build/
.pnp
.pnp.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ── 环境变量（敏感配置） ─────────────
