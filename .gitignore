*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# 虚拟环境
backend/venv/
backend/.venv/
venv/
.venv/
env/

# 测试 / 覆盖率
.pytest_cache/
.coverage
htmlcov/
*.cover

# ── Node / Next.js ───────────────────
node_modules/
frontend/node_modules/
